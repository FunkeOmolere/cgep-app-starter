            "description": "NIST 800-53 Rev 5 controls implemented by the Acme Health intake workload.",
            "implemented-requirements": [
              {
                "uuid": "885ae494-d9c8-461b-af07-8b260a838f31",
                "control-id": "sc-28",
                "description": "S3 uploads bucket encrypted with customer-managed KMS key via aws_s3_bucket_server_side_encryption_configuration. DynamoDB table encrypted with CMK via server_side_encryption block. KMS key has rotation enabled.",
                "props": [
                  {"name": "implementation-status", "value": "implemented"},
                  {"name": "terraform-resource", "value": "aws_s3_bucket_server_side_encryption_configuration.uploads"},
                  {"name": "terraform-resource", "value": "aws_dynamodb_table.intake"},
                  {"name": "rego-policy", "value": "policies/sc28_encryption_aws.rego"}
                ],
                "links": [
