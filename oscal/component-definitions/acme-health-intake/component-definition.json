                    "rel": "evidence",
                    "href": "s3://cgep-lab-grc-evidence-vault-72cfa176/runs/test-001/",
                    "text": "Signed pipeline evidence bundle containing terraform plan.json and conftest results."
                  }
                ]
              },
              {
                "uuid": "88a4e161-df46-4ada-9ab0-2aee2cd48f6f",
                "control-id": "ac-3",
                "description": "S3 public access block enforced via aws_s3_bucket_public_access_block. Lambda deployed in VPC with security group restricting egress to port 443 only. IAM policy scoped to least-privilege actions.",
                "props": [
                  {"name": "implementation-status", "value": "implemented"},
                  {"name": "terraform-resource", "value": "aws_s3_bucket_public_access_block.uploads"},
                  {"name": "terraform-resource", "value": "aws_lambda_function.intake"},
                  {"name": "rego-policy", "value": "policies/ac3_no_public_aws.rego"}
