        "type": "software",
        "title": "Acme Health Patient Intake API",
        "description": "Serverless patient intake API on AWS comprising S3, DynamoDB, Lambda, and API Gateway. Gap-closed via Terraform overrides and governed by a Rego policy suite and GitHub Actions pipeline.",
        "purpose": "Provide a compliant-by-default patient intake workload satisfying SOC 2 Type II Trust Services Criteria.",
        "responsible-roles": [
          {
            "role-id": "provider",
            "party-uuids": ["5db18123-66e5-4f28-ba71-1232e3b2ccd6"]
          }
        ],
